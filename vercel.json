{
    "cleanUrls": true,
    "rewrites": [
        { "source": "/blog", "destination": "https://cleanmails-blogs.vercel.app/blog" },
        { "source": "/blog/:path*", "destination": "https://cleanmails-blogs.vercel.app/blog/:path*" },
        { "source": "/tools", "destination": "https://cleanmails-tools.vercel.app/tools" },
        { "source": "/tools/:path*", "destination": "https://cleanmails-tools.vercel.app/tools/:path*" },
        { "source": "/docs", "destination": "https://cleanmails-docs.vercel.app/docs" },
        { "source": "/docs/:path*", "destination": "https://cleanmails-docs.vercel.app/docs/:path*" }
    ]
}
